# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Railway, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/mathbord"

# ─── Authentication ───────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Lessonspace ──────────────────────────────────────────────
LESSONSPACE_API_KEY="your-lessonspace-api-key"

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY="re_..."
FROM_EMAIL="hello@mathbord.com"
ADMIN_EMAIL="admin@mathbord.com"

# ─── File Storage (AWS S3 or Cloudflare R2) ───────────────────
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="mathbord-files"
AWS_S3_REGION="ca-central-1"

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
